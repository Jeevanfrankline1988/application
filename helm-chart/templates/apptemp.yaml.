apiVersion: apps/v1
kind: Deployment
metadata:
  name: pygame-pygame
spec:
  replicas: 1
  selector:
    matchLabels:
      app: pygame-pygame
  template:
    metadata:
      labels:
        app: pygame-pygame
    spec:
      containers:
        - name: pygame-pygame
          image: jeevan725/pygame:latest  # Ensure this is your rebuilt image
          imagePullPolicy: Always
          ports:
            - containerPort: 5000
          # Do NOT mount a volume on /app, so templates from image are visible
          # If you need volumes, mount them under a subpath like /app/data
      # No volumes section required unless you have other data
